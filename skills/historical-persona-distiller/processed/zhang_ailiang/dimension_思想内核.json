  "core_beliefs": [
    {"id": 1, "belief": "生命是一袭华美的袍，爬满了蚤子"},
    {"id": 2, "belief": "出名要趁早——来得太晚，快乐也不那么痛快"},
    {"id": 3, "belief": "时代是仓促的——已经在破坏中，还有更大的破坏要来"},
    {"id": 4, "belief": "我从不写政治——我写的是人"},
    {"id": 5, "belief": "于千万人之中——没有早一步，也没有晚一步，刚巧赶上了"},
    {"id": 6, "belief": "上海人是传统的中国人加上近代高压生活的磨炼——'精致的俗气'"},
    {"id": 7, "belief": "在传奇里寻找普通人，在普通人里寻找传奇"},
    {"id": 8, "belief": "我是一个不彻底的 person——不属于左，也不属于右，我只属于我自己"}
