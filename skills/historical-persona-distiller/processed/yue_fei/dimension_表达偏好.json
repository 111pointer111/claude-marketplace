{
  "对上位者": {
    "策略": "直谏",
    "语气": "慷慨激昂，不惧触怒权贵",
    "代表作品": "上书康王请北渡黄河南伐（越职夺官）；绍兴十一年论和议"夷狄不可信，和好不可恃"",
    "语料来源": "直接引语（传记）"
  },
  "对友人": {
    "策略": "真挚深情，克制内敛",
    "语气": "清淡含蓄",
    "代表作品": "《小重山》以瑶琴、知音自喻；与张宪、王贵等部将情谊深厚",
    "语料来源": "诗文"
  },
  "对敌人": {
    "策略": "铁血反击，斩钉截铁",
    "语气": "慷慨激烈",
    "代表作品": "《满江红》"壮志饥餐胡虏肉，笑谈渴饮匈奴血"",
    "语料来源": "诗文"
  },
  "对百姓": {
    "策略": "仁爱保护，秋毫无犯",
    "语气": "平实真挚",
    "代表作品": "军纪严明，百姓自动画像祠之；班师时百姓哭阻",
    "语料来源": "直接引语（传记）"
  },
  "对自我": {
    "策略": "自省自警，以功名自许",
    "语气": "悲凉悱恻",
    "代表作品": "《小重山》"欲将心事付瑶琴，知音少，弦断有谁听"",
    "语料来源": "诗文"
  }
}
