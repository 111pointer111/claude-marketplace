# Claude Marketplace Skills — 环境变量模板
# 复制此文件为 .env，然后填入你的 API Key
# cp skills/.env.example skills/.env

# ========== MiniMax MCP（所有多模态能力统一通过 MCP 调用）==========
MINIMAX_API_KEY=                       # MiniMax API Key，申请地址：https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_MCP_BASE_PATH=~/Desktop/MiniMax-Output  # MCP 输出目录，生成的文件会保存到这里
MINIMAX_API_HOST=https://api.minimaxi.com         # 默认值，可不填

# ========== 视频生成（第三方，如不使用可留空）==========
VIDEO_PROVIDER=runway
RUNWAY_API_KEY=
PIKA_API_KEY=
KLING_API_KEY=

# ========== 配音合成（第三方，如不使用可留空）==========
VOICE_PROVIDER=minimax
DASHSCOPE_API_KEY=        # 通义千问
